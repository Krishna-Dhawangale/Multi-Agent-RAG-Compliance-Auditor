# .streamlit/secrets.toml.example
# Rename this file to secrets.toml and fill in your keys

ANTHROPIC_API_KEY = "your-anthropic-api-key"

# Optional: Set these for Qdrant Cloud deployment. 
# If not provided, the system falls back to in-memory Qdrant.
QDRANT_URL = "your-qdrant-cloud-url"
QDRANT_API_KEY = "your-qdrant-cloud-api-key"
